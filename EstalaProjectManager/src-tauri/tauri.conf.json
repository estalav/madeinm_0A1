{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Estala Project Manager",
  "version": "0.1.0",
  "identifier": "com.estala.projectmanager",
  "build": {
    "frontendDist": "../desktop-shell",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "npm run dev:desktop:web",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Estala Project Manager",
        "width": 1440,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "estalapm"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
